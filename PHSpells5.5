function importPHSpells() {
  const url = "https://raw.githubusercontent.com/5etools-mirror-3/5etools-src/refs/heads/main/data/spells/spells-phb.json";
  const response = UrlFetchApp.fetch(url);
  const json = JSON.parse(response.getContentText());
  const data = json.spell; 

  const sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();
  
  // We clear only the data area to preserve any specific sheet-wide formatting
  sheet.clearContents();

  // Headers - Added "Learned" as the first column
  const headers = ["Learned", "Name", "Level", "School", "Casting Time", "Range", "Duration", "Components", "Material Details", "Description"];
  sheet.appendRow(headers);

  const rows = data.map(spell => {
    // 1. Core Mechanics
    const time = spell.time ? `${spell.time[0].number} ${spell.time[0].unit}` : "N/A";
    
    let range = "Special";
    if (spell.range) {
      if (spell.range.type === "self") range = "Self";
      else if (spell.range.distance) range = `${spell.range.distance.amount} ${spell.range.distance.type}`;
      else range = spell.range.type;
    }

    let duration = "Instantaneous";
    if (spell.duration && spell.duration[0]) {
      const d = spell.duration[0];
      if (d.type !== "instant") {
        duration = d.amount ? `${d.amount} ${d.unit}` : d.type;
        if (d.concentration) duration = "Conc., " + duration;
      }
    }

    // 2. Components & Materials
    const comps = spell.components ? Object.keys(spell.components).join(", ").toUpperCase() : "NONE";
    let materialDetails = "";
    if (spell.components && spell.components.m) {
      materialDetails = typeof spell.components.m === 'object' ? (spell.components.m.text || "") : spell.components.m;
      if (spell.components.m.consume) materialDetails += " (CONSUMED)";
    }

    // 3. Clean Description
    let desc = spell.entries ? spell.entries.join("\n\n") : "";
    desc = desc.replace(/\{@[a-z]+ ([^}]+)\}/g, '$1'); 

    // Return the row, leaving the first index empty for the checkbox
    return ["", spell.name, spell.level, spell.school, time, range, duration, comps, materialDetails, desc];
  });

  sheet.getRange(2, 1, rows.length, 10).setValues(rows);
  
  // Apply Checkboxes to Column A
  const checkboxRange = sheet.getRange(2, 1, rows.length, 1);
  checkboxRange.insertCheckboxes();

  // Aesthetic Formatting
  sheet.getRange(1, 1, 1, 10).setFontWeight("bold").setBackground("#4C0000").setFontColor("#FFFFFF");
  sheet.setColumnWidth(1, 70);   // Checkbox column width
  sheet.setColumnWidth(10, 500); // Description column width
  sheet.getRange(2, 10, sheet.getLastRow() - 1, 1).setWrap(true);
}
