function import5etoolspells() {
  const sources = [
    { name: "PHB", url: "https://raw.githubusercontent.com/5etools-mirror-3/5etools-src/refs/heads/main/data/spells/spells-phb.json" },
    { name: "XGE", url: "https://raw.githubusercontent.com/5etools-mirror-3/5etools-src/refs/heads/main/data/spells/spells-xge.json" },
    { name: "TCE", url: "https://raw.githubusercontent.com/5etools-mirror-3/5etools-src/refs/heads/main/data/spells/spells-tce.json" }
  ];

  const sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();
  
  // Preserve existing "Learned" checkboxes by only clearing the data, or clear all to reset
  sheet.clearContents();

  // Headers - Added "Source"
  const headers = ["Learned", "Name", "Source", "Level", "School", "Casting Time", "Range", "Duration", "Components", "Material Details", "Description"];
  sheet.appendRow(headers);

  let allRows = [];

  sources.forEach(source => {
    try {
      const response = UrlFetchApp.fetch(source.url);
      const json = JSON.parse(response.getContentText());
      const spells = json.spell;

      const bookRows = spells.map(spell => {
        // Casting Time
        const time = spell.time ? `${spell.time[0].number} ${spell.time[0].unit}` : "N/A";
        
        // Range
        let range = "Special";
        if (spell.range) {
          if (spell.range.type === "self") range = "Self";
          else if (spell.range.distance) range = `${spell.range.distance.amount} ${spell.range.distance.type}`;
          else range = spell.range.type;
        }

        // Duration
        let duration = "Instantaneous";
        if (spell.duration && spell.duration[0]) {
          const d = spell.duration[0];
          if (d.type !== "instant") {
            duration = d.amount ? `${d.amount} ${d.unit}` : d.type;
            if (d.concentration) duration = "Conc., " + duration;
          }
        }

        // Components & Materials
        const comps = spell.components ? Object.keys(spell.components).join(", ").toUpperCase() : "NONE";
        let materialDetails = "";
        if (spell.components && spell.components.m) {
          materialDetails = typeof spell.components.m === 'object' ? (spell.components.m.text || "") : spell.components.m;
          if (spell.components.m.consume) materialDetails += " (CONSUMED)";
        }

        // Clean Description
        let desc = spell.entries ? spell.entries.join("\n\n") : "";
        desc = desc.replace(/\{@[a-z]+ ([^}]+)\}/g, '$1'); 

        return ["", spell.name, source.name, spell.level, spell.school, time, range, duration, comps, materialDetails, desc];
      });

      allRows = allRows.concat(bookRows);
    } catch (e) {
      Logger.log("Error loading " + source.name + ": " + e);
    }
  });

  // Sort all spells alphabetically by Name (Column B)
  allRows.sort((a, b) => a[1].localeCompare(b[1]));

  // Paste data and insert checkboxes
  if (allRows.length > 0) {
    sheet.getRange(2, 1, allRows.length, 11).setValues(allRows);
    sheet.getRange(2, 1, allRows.length, 1).insertCheckboxes();
  }

  // Formatting
  sheet.getRange(1, 1, 1, 11).setFontWeight("bold").setBackground("#4C0000").setFontColor("#FFFFFF");
  sheet.setColumnWidth(11, 500); 
  sheet.getRange(2, 11, sheet.getLastRow() - 1, 1).setWrap(true);
}
